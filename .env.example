# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

SECRET_KEY=sua-chave-secreta-muito-segura-aqui
DEBUG=False
ALLOWED_HOSTS=seu-dominio.onrender.com,localhost

# Para desenvolvimento local, deixe em branco (usa SQLite)
# Para produção no Render, use a URL do PostgreSQL fornecida
DATABASE_URL=postgres://user:password@host:5432/dbname
